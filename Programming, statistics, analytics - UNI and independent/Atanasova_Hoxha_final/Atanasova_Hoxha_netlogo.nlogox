  <previewCommands>setup repeat 75 [ go ]</previewCommands>
  <experiments>
    <experiment name="Exp_1" repetitions="30" sequentialRunOrder="true" runMetricsEveryStep="false">
      <setup>setup</setup>
      <go>go</go>
      <exitCondition>ticks = 1000</exitCondition>
      <metrics>
        <metric>total-delivered-value</metric>
        <metric>total-seized-value</metric>
        <metric>count links</metric>
        <metric>first-yellow-tick</metric>
        <metric>count links with [color = yellow]</metric>
        <metric>(sum [flow-count] of links with [color = yellow]) / (sum [flow-count] of links + 0.0001)</metric>
        <metric>(mean [nw:clustering-coefficient] of nodes)</metric>
      </metrics>
      <constants>
        <enumeratedValueSet variable="preset-scenario">
          <value value="&quot;Exp 1: Adaptive, Busiest, Short&quot;"></value>
        </enumeratedValueSet>
      </constants>
    </experiment>
