  [ 100 ])]]></monitor>
    <monitor x="1695" precision="17" y="245" height="60" fontSize="11" width="110" display="% 10 ticks Seizure, reset at 90"><![CDATA[(ifelse-value (recent-delivered + recent-seized) > 0 
  [ precision (recent-seized / (recent-delivered + recent-seized) * 100) 1 ] 
  [ 0 ])]]></monitor>
    <monitor x="1570" precision="17" y="315" height="60" fontSize="11" width="115" display="Snapshot 90 days delivered">snapshot-delivered</monitor>
    <monitor x="1695" precision="17" y="315" height="60" fontSize="11" width="110" display="Snapshot 90 days seized">snapshot-seized</monitor>
    <monitor x="1695" precision="17" y="380" height="60" fontSize="11" width="115" display="% snapshot delivered 90 days"><![CDATA[(ifelse-value (snapshot-delivered + snapshot-seized) > 0 
  [ precision (snapshot-delivered / (snapshot-delivered + snapshot-seized) * 100) 1 ] 
  [ 100 ])]]></monitor>
    <monitor x="1570" precision="17" y="380" height="60" fontSize="11" width="115" display="% snapshot seized"><![CDATA[(ifelse-value (snapshot-delivered + snapshot-seized) > 0 
  [ precision (snapshot-seized / (snapshot-delivered + snapshot-seized) * 100) 1 ] 
  [ 0 ])]]></monitor>
