    <monitor x="1430" precision="17" y="655" height="67" fontSize="11" width="112" display="Total Active Routes">count links</monitor>
    <monitor x="1570" precision="17" y="35" height="60" fontSize="11" width="115" display="Total Delivered">total-delivered-value</monitor>
    <monitor x="1695" precision="17" y="35" height="60" fontSize="11" width="110" display="Total Seized">total-seized-value</monitor>
    <monitor x="1570" precision="17" y="105" height="60" fontSize="11" width="115" display="% Delivery Rate "><![CDATA[ifelse-value ((total-delivered-value + total-seized-value) > 0) [ precision ((total-delivered-value / (total-delivered-value + total-seized-value)) * 100) 1 ] [ 0 ]]]></monitor>
    <monitor x="1695" precision="17" y="105" height="60" fontSize="11" width="110" display="% Seizure Rate "><![CDATA[ifelse-value ((total-delivered-value + total-seized-value) > 0) [ precision ((total-seized-value / (total-delivered-value + total-seized-value)) * 100) 1 ] [ 0 ]]]></monitor>
    <monitor x="1570" precision="17" y="175" height="60" fontSize="11" width="115" display="10 ticks Delivery, reset at 90">recent-delivered</monitor>
