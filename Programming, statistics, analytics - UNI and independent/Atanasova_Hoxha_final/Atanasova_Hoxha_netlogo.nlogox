<?xml version="1.0" encoding="utf-8"?>
<model version="NetLogo 7.0.3" snapToGrid="true">
  <code><![CDATA[extensions [ nw ] ; Load the Network Extension for advanced pathfinding and SNA metrics

breed [ nodes node ]
breed [ shipments shipment ]
breed [ police-markers police-marker ]

nodes-own [
  role              ; Define if node is "supply", "transit", or "demand"
  perceived-risk    ; Local memory of risk (0-100); used to calculate route-weight
  police-presence   ; Countdown timer: how many days police remain at this hub
]

police-markers-own [
  my-node ; Pointer variable to link the visual star to the specific occupied node
]

links-own [
  base-cost         ; Static physical distance/transport cost (invariant)
  route-weight      ; Dynamic cost: base-cost + node risk (used by the NW extension)
  flow-count        ; Traffic volume tracker for the Flow Displacement Index (FDI)
  days-since-used   ; Counter to track inactivity for infrastructure degradation
]

globals [
  total-seized-value    ; Cumulative counter for all shipments lost to police
  total-delivered-value ; Cumulative counter for all successful deliveries
  recent-seized         ; Short-term seizure tally for the recent performance plot
  recent-delivered      ; Short-term delivery tally for the recent performance plot
  window-seized         ; Seizures within the current 90-day rolling window
  window-delivered      ; Deliveries within the current 90-day rolling window
  memory-window         ; Fixed at 90; the "memory" length for cartel adaptation
  snapshot-seized       ; Stored window value for plotting/analysis
  snapshot-delivered    ; Stored window value for plotting/analysis
  first-yellow-tick     ; Timestamp of the very first adaptation (Balloon Effect)
] 

shipments-own [
  target-node ; The destination "demand" node assigned at birth
]

to setup
  apply-scenario  ; Loads experimental presets (Exp 1-8) before setup
  clear-all
  set memory-window 90   ; Define the cartel's observation period
  set first-yellow-tick -1
  set-default-shape nodes "circle"
  set-default-shape shipments "box"
  
  ; 1. Generate the Scale-Free Network (Barabási-Albert model)
  ; Creates a "Hub-and-Spoke" topology where a few nodes have many connections
  nw:generate-preferential-attachment nodes links total-nodes 2
  
  ; 2. Assign Roles based on Degree Centrality
  ; We sort nodes by connection count: low-degree become supply/demand, high-degree become transit hubs
  let sorted-nodes sort-by [ [a b] -> count [link-neighbors] of a < count [link-neighbors] of b ] nodes
  
  ; Calculate role distribution based on UI slider percentages
  let supply-count round (total-nodes * (percent-supply / 100))
  let demand-count round (total-nodes * (percent-demand / 100))
  
  let n 0
  foreach sorted-nodes [ current-node ->
    ask current-node [
      ifelse n < supply-count [
        set role "supply" ; Green source nodes
        set color green
        set size 1.5
      ] [
        ifelse n < (supply-count + demand-count) [
          set role "demand" ; Red market nodes
          set color red
          set size 1.5
        ] [
          set role "transit" ; Grey logistics hubs
          set color gray
          ; Scale visual size by connectivity to visually represent hubs
          set size 1 + (count link-neighbors / 4)
        ]
      ]
      set perceived-risk 0
      set police-presence 0
    ]
    set n n + 1
  ]
  
  ; 3. Initialize Link Attributes
  ask links [
    set base-cost 1 + random-float 5 ; Simulates geographic distance
    set route-weight base-cost       ; At t=0, cost is purely distance-based
    set flow-count 0                 
    set days-since-used 0            ; All links start "fresh"
  ]
  
  ; 4. Visual Layout
  ; Spring layout pushes hubs to the center and leaves spokes on the periphery
  repeat 150 [ layout-spring nodes links 0.2 12 4 ]
  
  reset-ticks
end

to go
  ; 1. Spawning Shipments: Supply nodes generate product based on spawn-chance
  ask nodes with [role = "supply"] [
    if random 100 < spawn-chance [
      hatch-shipments 1 [
        set color yellow
        set size 1.5
        let my-destination one-of nodes with [role = "demand"]
        set target-node my-destination
      ]
    ]
  ]

  ; 2. Moving Shipments: Agents navigate the network using Dijkstra's algorithm
  ask shipments [
    ifelse patch-here = [patch-here] of target-node [
      ; SUCCESS: Shipment reached demand node
      set total-delivered-value total-delivered-value + 1
      set recent-delivered recent-delivered + 1
      set window-delivered window-delivered + 1
      die
    ] [
      let current-node one-of nodes-here
      let my-target target-node
      let next-step-node nobody

      ask current-node [
        ; Find the path with the LOWEST route-weight (balancing cost and risk)
        let best-path nw:weighted-path-to my-target "route-weight"
        if best-path != false and not empty? best-path [
          let next-link first best-path
          set next-step-node [other-end] of next-link
          ask next-link [
            set flow-count flow-count + 1 ; Record traffic for FDI metric
            set days-since-used 0        ; Reset inactivity timer
          ]
        ]
      ]

      ifelse next-step-node != nobody [
        move-to next-step-node
      ] [
        ; FAILURE: No path available (network is fragmented or too risky)
        set total-seized-value total-seized-value + 1
        set window-seized window-seized + 1
        set recent-seized recent-seized + 1
        die
      ]
    ]
  ]                

  ; 3. Enforcement Logic: Handle new raids and ongoing occupations
  interdict
    ask police-markers [
    if [police-presence] of my-node = 0 [ die ]
  ]
  decay-risk            ; Gradually lower node risk levels as memories fade
  update-route-weights  ; Re-calculate the "cost" of every link for the next tick

  ; 4. Adaptation Logic: The cartel responds to pressure
  adapt-network         ; Builds new "yellow" links if losses are too high
  reset-window          ; Manages the 90-day rolling memory cycles
  update-visuals        ; Adjusts hub sizes based on new connections
  prune-dead-routes     ; Removes unused infrastructure (degradation)
  do-plotting           ; Updates charts

  wait 0.1 ; Delay to make the simulation visible to the user

  tick
end

to prune-dead-routes
  ; Simulates the removal of abandoned routes or infrastructure decay
  ask links [
    set days-since-used days-since-used + 1
    
    ; If a route hasn't been used in 180 days, it is removed from the network
    if days-since-used > 180 [
      die
    ]
  ]
end

to interdict
  ; 1. TRIGGER NEW RAIDS: Decide if a new enforcement action occurs
  if random 100 < enforcement-chance [
    let raid-target nobody  
    
    ; Targeting Strategy: Either pick a random hub or the one with most current traffic
    ifelse target-strategy = "Random Transit" [
      set raid-target one-of nodes with [role = "transit"]
    ] [
      set raid-target max-one-of (nodes with [role = "transit"]) [count shipments-here]
    ]
    
    ; If a target is found, set up the occupation
    if raid-target != nobody [
      ask raid-target [
        set police-presence enforcement-duration ; Police stay for X ticks
        set perceived-risk 100                  ; Risk spikes to maximum
        set color orange                        ; Node turns orange (Active Raid)
        ]
        ; Place the blue star marker
        if not any? police-markers with [my-node = raid-target] [
          create-police-markers 1 [
            set shape "star"
            set color blue
            set size 2
            move-to raid-target
            set my-node raid-target
          ]
      ]
    ]
  ]

  ; 2. EXECUTE ONGOING OCCUPATIONS: Seize product passing through raid zones
  ask nodes with [police-presence > 0] [
    let seized count shipments-here
    if seized > 0 [
      set total-seized-value total-seized-value + seized
      set recent-seized recent-seized + seized
      set window-seized window-seized + seized  
      ask shipments-here [ die ] ; Shipment is destroyed/seized
    ]
    
    ; Decrement the occupation timer
    set police-presence police-presence - 1
   
  ]
end

to update-route-weights
  ; Recalculate edge weights: cost = physical distance + risk of start/end nodes
  ; This forces the Dijkstra algorithm to find routes that avoid "hot" orange nodes
  ask links [
    let node1 end1
    let node2 end2
    set route-weight base-cost + ([perceived-risk] of node1) + ([perceived-risk] of node2)
  ]
end

to decay-risk
  ; Nodes eventually recover from raid stigma if no further action occurs
  ask nodes with [perceived-risk > 0 and police-presence = 0] [
    set perceived-risk perceived-risk - 5 ; Gradual decay
    if perceived-risk <= 0 [
      set perceived-risk 0
      if role = "transit" [ set color gray ] ; Return to normal transit color
    ]
  ]
end

to adapt-network
  ; The Balloon Effect Mechanism: Triggers new link creation if failure rates spike
  let window-total (window-delivered + window-seized)

  if window-total > 10 [
    let failure-rate (window-seized / window-total) * 100

    ; Compare recent performance against the cartel's internal loss-tolerance
    if failure-rate > loss-tolerance-threshold [

      ; OPTION 1: Rational Bypass (Connect neighbors of a currently raided node)
      let hot-node one-of nodes with [role = "transit" and perceived-risk > 0]

      ifelse hot-node != nobody [
        ; Identify safe neighbors of the hot node
        let safe-neighbors ([link-neighbors] of hot-node) with [
          role = "transit" and perceived-risk < 20
        ]
        if count safe-neighbors >= 2 [
          let candidate1 one-of safe-neighbors
          let candidate2 one-of safe-neighbors with [self != candidate1]
          if candidate1 != nobody and candidate2 != nobody [
            ask candidate1 [
              if not link-neighbor? candidate2 [
                create-link-with candidate2 [
                  set base-cost 1 + random-float 5
                  set route-weight base-cost
                  set color yellow ; Yellow signifies "new" infrastructure (adaptation)
                  set thickness 0.3
                  set flow-count 0
                  set days-since-used 0
                ]
                if first-yellow-tick = -1 [set first-yellow-tick ticks]
              ]
            ]
          ]
        ]
      ] [
        ; OPTION 2: General Redundancy (Connect random safe hubs)
        let candidate1 one-of nodes with [role = "transit" and perceived-risk < 20]
        let candidate2 one-of nodes with [role = "transit" and perceived-risk < 20]
        if candidate1 != nobody and candidate2 != nobody and candidate1 != candidate2 [
          ask candidate1 [
            if not link-neighbor? candidate2 [
              create-link-with candidate2 [
                set base-cost 1 + random-float 5
                set route-weight base-cost
                set color yellow
                set thickness 0.3
                set flow-count 0
                set days-since-used 0
              ]
              if first-yellow-tick = -1 [set first-yellow-tick ticks]
            ]
          ]
        ]
      ]
    ]
  ]
end

to reset-window
  ; Logic for the 90-day memory window reset
  if ticks mod memory-window = 0 [
    set snapshot-seized window-seized
    set snapshot-delivered window-delivered
    set window-seized 0
    set window-delivered 0
  ]
end

to do-plotting
  ; Update graph visualizations every 10 ticks for smoothness
   if ticks mod 10 = 0 [
    
    ; Plotting Cumulative Success
    set-current-plot "Cumulative Operational Success"
    set-current-plot-pen "Delivered"
    plotxy ticks total-delivered-value
    set-current-plot-pen "Seized"
    plotxy ticks total-seized-value
    
    ; Plotting the Systemic Risk level
    set-current-plot "Systemic Risk"
    set-current-plot-pen "Avg Hub Risk"
    let avg-risk mean [perceived-risk] of nodes with [role = "transit"]
    plotxy ticks avg-risk
    
    ; Plotting Network Expansion (Total links)
    set-current-plot "Network Expansion"
    set-current-plot-pen "Total Links"
    plotxy ticks count links
    
    ; Flow Displacement Index (FDI): Traffic on new routes vs total traffic
    set-current-plot "Flow Displacement"
    let baseline-flow sum [flow-count] of links with [color != yellow]
    let shifted-flow sum [flow-count] of links with [color = yellow]
    let total-flow (baseline-flow + shifted-flow)
    let current-fdi 0
    if total-flow > 0 [
      set current-fdi (shifted-flow / total-flow)
    ]
    set-current-plot-pen "FDI" 
    plotxy ticks current-fdi
    
    ; Reset the flow counters after plotting
    ask links [ set flow-count 0 ]

    ; SNA Metrics: Clustering Coefficient (Network Hardening)
    set-current-plot "Network Topology"   
    set-current-plot-pen "Clustering"
    plotxy ticks (mean [nw:clustering-coefficient] of nodes) * 100
    
    ; Recent Performance Plot (non-cumulative)
    set-current-plot "Recent Performance: 10 ticks, reset at memory window"
    set-current-plot-pen "Delivered (Recent)"
    plotxy ticks recent-delivered
    set-current-plot-pen "Seized (Recent)"
    plotxy ticks recent-seized
    
    ; Reset recent performance counters at the end of the memory window
    if ticks mod memory-window = 0 [  
      set recent-delivered 0
      set recent-seized 0
    ]
   
  ]
end
    
to update-visuals
  ; Resize nodes dynamically based on their connection count (degree centrality)
  ask nodes with [role = "transit"] [
    let new-size 1 + (count link-neighbors / 4)
    set size min (list new-size 4) ; Cap size for visual clarity
  ]
end

to apply-scenario
  ; EXPERIMENTAL SCENARIO FACTORY
  ; Enforces preset parameters for the 8 specific experimental runs
  if preset-scenario = "Custom" [ stop ]

  set total-nodes 110
  set spawn-chance 50
  set enforcement-chance 40
  set percent-supply 10
  set percent-demand 10

  ; Configure Experiment 1: High intelligence (Busiest), high reactivity (Adaptive), short duration
  if preset-scenario = "Exp 1: Adaptive, Busiest, Short" [
    set loss-tolerance-threshold 5    
    set target-strategy "Busiest Transit"
    set enforcement-duration 5        
  ]

  ; Configure Experiment 2: High intelligence, low reactivity (Stubborn), short duration
  if preset-scenario = "Exp 2: Stubborn, Busiest, Short" [
    set loss-tolerance-threshold 30   
    set target-strategy "Busiest Transit"
    set enforcement-duration 5        
  ]

  ; Configure Experiment 3: Random targeting, high reactivity (Adaptive), short duration
  if preset-scenario = "Exp 3: Adaptive, Random, Short" [
    set loss-tolerance-threshold 5    
    set target-strategy "Random Transit"
    set enforcement-duration 5        
  ]

  ; Configure Experiment 4: Random targeting, low reactivity (Stubborn), short duration
  if preset-scenario = "Exp 4: Stubborn, Random, Short" [
    set loss-tolerance-threshold 30   
    set target-strategy "Random Transit"
    set enforcement-duration 5        
  ]

  ; Configure Experiment 5: High intelligence, high reactivity (Adaptive), LONG duration
  if preset-scenario = "Exp 5: Adaptive, Busiest, Long" [
    set loss-tolerance-threshold 5    
    set target-strategy "Busiest Transit"
    set enforcement-duration 25       
  ]

  ; Configure Experiment 6: High intelligence, low reactivity (Stubborn), LONG duration
  if preset-scenario = "Exp 6: Stubborn, Busiest, Long" [
    set loss-tolerance-threshold 30   
    set target-strategy "Busiest Transit"
    set enforcement-duration 25       
  ]
  
  ; Configure Experiment 7: Random targeting, high reactivity (Adaptive), LONG duration
  if preset-scenario = "Exp 7: Adaptive, Random, Long" [
    set loss-tolerance-threshold 5   
    set target-strategy "Random Transit"
    set enforcement-duration 25       
  ]
  
  ; Configure Experiment 8: Random targeting, low reactivity (Stubborn), LONG duration
  if preset-scenario = "Exp 8: Stubborn, Random, Long" [
    set loss-tolerance-threshold 30   
    set target-strategy "Random Transit"
    set enforcement-duration 25       
  ]
end]]></code>
  <widgets>
